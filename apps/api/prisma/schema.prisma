model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  code        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  code      String   @unique @db.VarChar(150)
  module    String   @db.VarChar(100)
  action    String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@index([module, action])
  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  module     String   @db.VarChar(100)
  action     String   @db.VarChar(100)
  objectType String?  @map("object_type") @db.VarChar(100)
  objectId   String?  @map("object_id") @db.Uuid
  beforeData Json?    @map("before_data")
  afterData  Json?    @map("after_data")
  ip         String?  @db.VarChar(100)
  userAgent  String?  @map("user_agent") @db.Text
  remark     String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module, action])
  @@index([objectType, objectId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Attachment {
  id              String   @id @default(uuid()) @db.Uuid
  originalName    String   @map("original_name") @db.VarChar(255)
  storageKey      String   @unique @map("storage_key") @db.VarChar(500)
  mimeType        String   @map("mime_type") @db.VarChar(150)
  sizeBytes       BigInt   @map("size_bytes")
  businessModule  String?  @map("business_module") @db.VarChar(80)
  objectType      String?  @map("object_type") @db.VarChar(120)
  objectId        String?  @map("object_id") @db.Uuid
  purpose         String?  @db.VarChar(120)
  remark          String?  @db.Text
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy          User?                     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  renewalTasks       RenewalTask[]
  balanceAdjustments AppleBalanceAdjustment[]  @relation("AppleBalanceAdjustmentEvidence")
  statusChecks       AppleAccountStatusCheck[] @relation("AppleAccountStatusCheckEvidence")
  automationTasks    AutomationTask[]          @relation("AutomationTaskScreenshot")
  automationTaskLogs AutomationTaskLog[]       @relation("AutomationTaskLogScreenshot")

  @@index([createdByUserId])
  @@index([businessModule, objectType])
  @@index([objectId])
  @@index([purpose])
  @@index([createdAt])
  @@map("attachments")
}
