generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
}

enum CustomerStatus {
  active
  disabled
}

enum SourcePlatformStatus {
  active
  disabled
}

enum MessageTemplateType {
  renewal
  delivery
  after_sale
  notification
  custom
}

enum MessageTemplateChannel {
  internal
  telegram
  customer_service
}

enum MessageTemplateStatus {
  active
  disabled
}

enum AppleAccountStatus {
  normal
  need_verify
  locked
  password_error
  risk
  unknown
}

enum AppleServiceStatus {
  enabled
  paused
  disabled
}

enum AppleServicePeriodType {
  month
  day
  manual
}

enum AppleServiceExpireCalcType {
  by_month
  by_day
  manual
}

enum AppleServiceLockRule {
  by_service
  global
}

enum AppleOrderStatus {
  pending
  active
  completed
  cancelled
  abnormal
}

enum ServiceActivationStatus {
  active
  expired
  cancelled
  abnormal
}

enum AutoRenewStatus {
  enabled
  disabled
  unknown
}

enum RenewalDecision {
  unconfirmed
  renew
  no_renew
  change_plan
}

enum RenewalTaskType {
  contact_customer
  remind_customer_reply
  confirm_payment
  topup_apple_balance
  check_balance
  cancel_subscription
  change_plan
  wait_auto_renewal
  check_renewal_result
  notify_customer
  handle_abnormal
  after_sale
}

enum RenewalTaskStatus {
  pending
  processing
  waiting_customer
  waiting_payment
  waiting_auto_renewal
  waiting_manual_verify
  completed
  cancelled
  failed
  abnormal
  postponed
}

enum RenewalTaskPriority {
  low
  medium
  high
  urgent
}

enum RenewalTaskCustomerDecision {
  not_contacted
  contacted_waiting_reply
  confirmed_renewal
  confirmed_no_renewal
  change_plan
  considering
  paid
  unpaid
  cancelled
  renewed_success
  abnormal
}

enum AppleActionPlanStatus {
  pending
  processing
  completed
  abnormal
}

enum AppleActionPlanItemActionType {
  renew
  cancel
  change_plan
  wait_customer
}

enum AppleActionPlanItemStatus {
  pending
  completed
  abnormal
}

enum AppleAccountLockScope {
  by_service
  global
}

enum AppleAccountLockStatus {
  active
  released
  expired
}

enum AppleBalanceAdjustmentCostMethod {
  none
  current_avg
  manual
}

enum AppleAccountStatusCheckType {
  manual
  automation
}

enum AutomationTaskType {
  check_status
  check_balance
  topup
  cancel_subscription
  change_phone
  change_security
  check_renewal
}

enum AutomationTaskStatus {
  pending
  queued
  running
  waiting_manual_verify
  success
  failed
  skipped
  cancelled
  need_review
}

enum AutomationTaskPriority {
  low
  medium
  high
  urgent
}

enum AutomationTaskLogLevel {
  info
  warning
  error
  success
}

enum NotificationChannelType {
  telegram
  in_app
}

enum NotificationLevel {
  info
  warning
  error
  critical
}

enum NotificationLogStatus {
  pending
  sent
  failed
  skipped
}

enum TelegramTestStatus {
  not_tested
  success
  failed
}

enum AppleServicePlatformFeeType {
  none
  rate
  fixed
  mixed
}

enum CodeServiceStatus {
  enabled
  paused
  disabled
}

enum CodeDeliveryMode {
  auto
  semi_auto
  manual
}

enum RedeemCodeStatus {
  unsold
  locked
  delivered
  delivery_failed
  after_sale
  reissued
  voided
  refunded
}

enum CodeDeliveryStatus {
  pending
  delivered
  failed
  manual
}

enum CodeRefundStatus {
  none
  refunding
  refunded
}

enum CodeDeliveryMethod {
  eticket
  dummy_send
  message_card
  manual
}

enum CodeDeliveryLogStatus {
  success
  failed
  pending
}

enum CodeAfterSaleStatus {
  pending
  completed
  rejected
}

enum CodeRefundRecordStatus {
  refunding
  refunded
  rejected
}

enum LoginLogStatus {
  success
  failed
  blocked
}

enum IpWhitelistScope {
  admin
  api
  automation
}

enum SensitiveAccessApprovalStatus {
  pending
  approved
  rejected
  expired
}

enum DataJobStatus {
  pending
  running
  success
  failed
  cancelled
}

enum BackupJobType {
  database
  files
  config
}

enum DataDictionaryStatus {
  active
  disabled
}

enum OpsHealthStatus {
  normal
  warning
  error
  critical
  unknown
}

enum CronJobLogStatus {
  running
  success
  failed
  skipped
}

enum PlatformSyncLogStatus {
  success
  failed
}

enum ErrorLogLevel {
  info
  warn
  error
  fatal
}

enum AppAnnouncementLevel {
  info
  warning
  error
}

enum AppVersionStatus {
  draft
  released
  deprecated
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  username     String     @unique @db.VarChar(100)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  displayName  String     @map("display_name") @db.VarChar(100)
  phone        String?    @db.VarChar(50)
  email        String?    @db.VarChar(255)
  status       UserStatus @default(active)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  userRoles                UserRole[]
  auditLogs                AuditLog[]
  attachments              Attachment[]
  customersCreated         Customer[]                @relation("CustomerCreatedBy")
  customersUpdated         Customer[]                @relation("CustomerUpdatedBy")
  sourcePlatformsCreated   SourcePlatform[]          @relation("SourcePlatformCreatedBy")
  sourcePlatformsUpdated   SourcePlatform[]          @relation("SourcePlatformUpdatedBy")
  messageTemplatesCreated  MessageTemplate[]         @relation("MessageTemplateCreatedBy")
  messageTemplatesUpdated  MessageTemplate[]         @relation("MessageTemplateUpdatedBy")
  appleAccountsCreated     AppleAccount[]            @relation("AppleAccountCreatedBy")
  appleAccountsUpdated     AppleAccount[]            @relation("AppleAccountUpdatedBy")
  appleAccountsLocked      AppleAccount[]            @relation("AppleAccountLockedBy")
  appleTopupsCreated       AppleBalanceTopup[]       @relation("AppleBalanceTopupCreatedBy")
  appleConsumptionsCreated AppleBalanceConsumption[] @relation("AppleBalanceConsumptionCreatedBy")
  appleBalanceAdjustments  AppleBalanceAdjustment[]  @relation("AppleBalanceAdjustmentOperator")
  appleStatusChecks        AppleAccountStatusCheck[] @relation("AppleAccountStatusCheckOperator")
  appleServicesCreated     AppleService[]            @relation("AppleServiceCreatedBy")
  appleServicesUpdated     AppleService[]            @relation("AppleServiceUpdatedBy")
  appleOrdersCreated       AppleOrder[]              @relation("AppleOrderCreatedBy")
  appleOrdersUpdated       AppleOrder[]              @relation("AppleOrderUpdatedBy")
  appleAccountLocksCreated AppleAccountLock[]        @relation("AppleAccountLockCreatedBy")
  renewalTasksAssigned     RenewalTask[]             @relation("RenewalTaskAssignedTo")
  renewalTasksCreated      RenewalTask[]             @relation("RenewalTaskCreatedBy")
  renewalTasksCompleted    RenewalTask[]             @relation("RenewalTaskCompletedBy")
  actionPlansCreated       AppleAccountActionPlan[]  @relation("AppleActionPlanCreatedBy")
  actionPlansCompleted     AppleAccountActionPlan[]  @relation("AppleActionPlanCompletedBy")
  codeServicesCreated      CodeService[]             @relation("CodeServiceCreatedBy")
  codeServicesUpdated      CodeService[]             @relation("CodeServiceUpdatedBy")
  redeemCodeBatches        RedeemCodeBatch[]         @relation("RedeemCodeBatchImportedBy")
  codeAfterSalesHandled    CodeAfterSale[]           @relation("CodeAfterSaleHandledBy")
  automationTasksCreated   AutomationTask[]          @relation("AutomationTaskCreatedBy")
  notificationLogsRead     NotificationLog[]         @relation("NotificationLogReadBy")
  loginLogs                LoginLog[]                @relation("LoginLogUser")
  activeSessions           ActiveSession[]           @relation("ActiveSessionUser")
  securitySettingsUpdated  SecuritySetting[]         @relation("SecuritySettingUpdatedBy")
  ipWhitelistsCreated      IpWhitelist[]             @relation("IpWhitelistCreatedBy")
  sensitiveAccessLogs      SensitiveAccessLog[]      @relation("SensitiveAccessLogUser")
  sensitiveApprovalsAsked  SensitiveAccessApproval[] @relation("SensitiveAccessApprovalRequester")
  sensitiveApprovalsDone   SensitiveAccessApproval[] @relation("SensitiveAccessApprovalApprover")
  backupJobsCreated        BackupJob[]               @relation("BackupJobCreatedBy")
  restoreJobsCreated       RestoreJob[]              @relation("RestoreJobCreatedBy")
  dataImportJobsCreated    DataImportJob[]           @relation("DataImportJobCreatedBy")
  dataExportJobsCreated    DataExportJob[]           @relation("DataExportJobCreatedBy")
  recycleBinRecordsDeleted RecycleBinRecord[]        @relation("RecycleBinRecordDeletedBy")
  recycleBinRecordsRestored RecycleBinRecord[]       @relation("RecycleBinRecordRestoredBy")
  systemParametersUpdated  SystemParameter[]         @relation("SystemParameterUpdatedBy")
  dataDictionariesCreated  DataDictionary[]          @relation("DataDictionaryCreatedBy")
  dataDictionariesUpdated  DataDictionary[]          @relation("DataDictionaryUpdatedBy")
  dataCleanupJobsCreated   DataCleanupJob[]          @relation("DataCleanupJobCreatedBy")
  duplicateMergeJobsCreated DuplicateMergeJob[]      @relation("DuplicateMergeJobCreatedBy")
  appAnnouncementsCreated  AppAnnouncement[]         @relation("AppAnnouncementCreatedBy")
  appAnnouncementsUpdated  AppAnnouncement[]         @relation("AppAnnouncementUpdatedBy")
  maintenanceWindowsCreated MaintenanceWindow[]      @relation("MaintenanceWindowCreatedBy")
  maintenanceWindowsUpdated MaintenanceWindow[]      @relation("MaintenanceWindowUpdatedBy")
  featureFlagsUpdated      FeatureFlag[]             @relation("FeatureFlagUpdatedBy")
  appVersionsCreated       AppVersion[]              @relation("AppVersionCreatedBy")
  tableViews               UserTableView[]           @relation("UserTableViewUser")

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Customer {
  id               String         @id @default(uuid()) @db.Uuid
  name             String         @db.VarChar(120)
  phone            String?        @db.VarChar(50)
  phoneTail        String?        @map("phone_tail") @db.VarChar(8)
  wechat           String?        @db.VarChar(120)
  sourcePlatformId String?        @map("source_platform_id") @db.Uuid
  tags             String[]       @default([])
  remark           String?        @db.Text
  status           CustomerStatus @default(active)
  createdByUserId  String?        @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?        @map("updated_by_user_id") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?      @map("deleted_at") @db.Timestamptz(6)

  sourcePlatform              SourcePlatform?              @relation(fields: [sourcePlatformId], references: [id], onDelete: SetNull)
  createdBy                   User?                        @relation("CustomerCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy                   User?                        @relation("CustomerUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  appleOrders                 AppleOrder[]
  activations                 ServiceActivation[]
  renewalTasks                RenewalTask[]
  appleAccountActionPlanItems AppleAccountActionPlanItem[]
  automationTasks             AutomationTask[]

  @@index([name])
  @@index([phoneTail])
  @@index([sourcePlatformId])
  @@index([status])
  @@index([deletedAt])
  @@map("customers")
}

model SourcePlatform {
  id              String               @id @default(uuid()) @db.Uuid
  name            String               @db.VarChar(120)
  feeRate         Decimal              @default(0) @map("fee_rate") @db.Decimal(8, 4)
  feeFixed        Decimal              @default(0) @map("fee_fixed") @db.Decimal(12, 2)
  status          SourcePlatformStatus @default(active)
  remark          String?              @db.Text
  createdByUserId String?              @map("created_by_user_id") @db.Uuid
  updatedByUserId String?              @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?            @map("deleted_at") @db.Timestamptz(6)

  customers                    Customer[]
  appleOrders                  AppleOrder[]
  activations                  ServiceActivation[]
  appleServicePlatformMappings AppleServicePlatformMapping[]
  deliveredRedeemCodes         RedeemCode[]                  @relation("RedeemCodeDeliveredPlatform")
  codePlatformMappings         CodePlatformMapping[]
  codePlatformOrders           CodePlatformOrder[]
  codeDeliveryLogs             CodeDeliveryLog[]
  codeRefundRecords            CodeRefundRecord[]
  appleAccounts                AppleAccount[]
  createdBy                    User?                         @relation("SourcePlatformCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy                    User?                         @relation("SourcePlatformUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([deletedAt])
  @@map("source_platforms")
}

model MessageTemplate {
  id              String                 @id @default(uuid()) @db.Uuid
  name            String                 @db.VarChar(120)
  type            MessageTemplateType    @default(custom)
  channel         MessageTemplateChannel @default(internal)
  content         String                 @db.Text
  variables       String[]               @default([])
  status          MessageTemplateStatus  @default(active)
  remark          String?                @db.Text
  createdByUserId String?                @map("created_by_user_id") @db.Uuid
  updatedByUserId String?                @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?              @map("deleted_at") @db.Timestamptz(6)

  createdBy            User?                 @relation("MessageTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy            User?                 @relation("MessageTemplateUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  codePlatformMappings CodePlatformMapping[] @relation("CodePlatformMappingDeliveryTemplate")

  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([deletedAt])
  @@map("message_templates")
}

model AppleAccount {
  id                     String             @id @default(uuid()) @db.Uuid
  appleId                String             @map("apple_id") @db.VarChar(255)
  appleIdNormalized      String             @unique @map("apple_id_normalized") @db.VarChar(255)
  region                 String             @default("US") @db.VarChar(50)
  currency               String             @default("USD") @db.VarChar(10)
  currentBalance         Decimal            @default(0) @map("current_balance") @db.Decimal(18, 4)
  balanceCostAmount      Decimal            @default(0) @map("balance_cost_amount") @db.Decimal(18, 4)
  averageCost            Decimal            @default(0) @map("average_cost") @db.Decimal(18, 8)
  status                 AppleAccountStatus @default(normal)
  isManuallyLocked       Boolean            @default(false) @map("is_manually_locked")
  manualLockReason       String?            @map("manual_lock_reason") @db.Text
  sourcePlatformId       String?            @map("source_platform_id") @db.Uuid
  lockedAt               DateTime?          @map("locked_at") @db.Timestamptz(6)
  lockedByUserId         String?            @map("locked_by_user_id") @db.Uuid
  passwordEncrypted      String?            @map("password_encrypted") @db.Text
  securityInfoEncrypted  String?            @map("security_info_encrypted") @db.Text
  phoneEncrypted         String?            @map("phone_encrypted") @db.Text
  recoveryEmailEncrypted String?            @map("recovery_email_encrypted") @db.Text
  remark                 String?            @db.Text
  createdByUserId        String?            @map("created_by_user_id") @db.Uuid
  updatedByUserId        String?            @map("updated_by_user_id") @db.Uuid
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt              DateTime?          @map("deleted_at") @db.Timestamptz(6)

  createdBy       User?                     @relation("AppleAccountCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?                     @relation("AppleAccountUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  lockedBy        User?                     @relation("AppleAccountLockedBy", fields: [lockedByUserId], references: [id], onDelete: SetNull)
  sourcePlatform  SourcePlatform?           @relation(fields: [sourcePlatformId], references: [id], onDelete: SetNull)
  topups          AppleBalanceTopup[]
  consumptions    AppleBalanceConsumption[]
  adjustments     AppleBalanceAdjustment[]
  statusChecks    AppleAccountStatusCheck[]
  orders          AppleOrder[]
  activations     ServiceActivation[]
  locks           AppleAccountLock[]
  renewalTasks    RenewalTask[]
  actionPlans     AppleAccountActionPlan[]
  automationTasks AutomationTask[]

  @@index([status])
  @@index([currency])
  @@index([isManuallyLocked])
  @@index([sourcePlatformId])
  @@index([deletedAt])
  @@map("apple_accounts")
}

model AppleBalanceTopup {
  id                    String   @id @default(uuid()) @db.Uuid
  appleAccountId        String   @map("apple_account_id") @db.Uuid
  faceValue             Decimal  @map("face_value") @db.Decimal(18, 4)
  costAmount            Decimal  @map("cost_amount") @db.Decimal(18, 4)
  balanceBefore         Decimal  @map("balance_before") @db.Decimal(18, 4)
  balanceAfter          Decimal  @map("balance_after") @db.Decimal(18, 4)
  costBefore            Decimal  @map("cost_before") @db.Decimal(18, 4)
  costAfter             Decimal  @map("cost_after") @db.Decimal(18, 4)
  avgCostBefore         Decimal  @map("avg_cost_before") @db.Decimal(18, 8)
  avgCostAfter          Decimal  @map("avg_cost_after") @db.Decimal(18, 8)
  giftCardCodeEncrypted String?  @map("gift_card_code_encrypted") @db.Text
  giftCardCodeHash      String?  @unique @map("gift_card_code_hash") @db.VarChar(128)
  giftCardCodeTail      String?  @map("gift_card_code_tail") @db.VarChar(8)
  remark                String?  @db.Text
  createdByUserId       String?  @map("created_by_user_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  appleAccount AppleAccount @relation(fields: [appleAccountId], references: [id], onDelete: Restrict)
  createdBy    User?        @relation("AppleBalanceTopupCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([appleAccountId])
  @@index([createdAt])
  @@map("apple_balance_topups")
}

model AppleBalanceConsumption {
  id                String   @id @default(uuid()) @db.Uuid
  appleAccountId    String   @map("apple_account_id") @db.Uuid
  amount            Decimal  @db.Decimal(18, 4)
  costAmount        Decimal  @map("cost_amount") @db.Decimal(18, 4)
  avgUnitCost       Decimal  @map("avg_unit_cost") @db.Decimal(18, 8)
  balanceBefore     Decimal  @map("balance_before") @db.Decimal(18, 4)
  balanceAfter      Decimal  @map("balance_after") @db.Decimal(18, 4)
  costBefore        Decimal  @map("cost_before") @db.Decimal(18, 4)
  costAfter         Decimal  @map("cost_after") @db.Decimal(18, 4)
  reason            String?  @db.VarChar(120)
  relatedObjectType String?  @map("related_object_type") @db.VarChar(120)
  relatedObjectId   String?  @map("related_object_id") @db.Uuid
  remark            String?  @db.Text
  createdByUserId   String?  @map("created_by_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  appleAccount AppleAccount @relation(fields: [appleAccountId], references: [id], onDelete: Restrict)
  createdBy    User?        @relation("AppleBalanceConsumptionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([appleAccountId])
  @@index([createdAt])
  @@map("apple_balance_consumptions")
}

model AppleBalanceAdjustment {
  id                   String                           @id @default(uuid()) @db.Uuid
  appleAccountId       String                           @map("apple_account_id") @db.Uuid
  oldBalance           Decimal                          @map("old_balance") @db.Decimal(18, 4)
  newBalance           Decimal                          @map("new_balance") @db.Decimal(18, 4)
  difference           Decimal                          @db.Decimal(18, 4)
  oldCostRmb           Decimal                          @map("old_cost_rmb") @db.Decimal(18, 4)
  newCostRmb           Decimal                          @map("new_cost_rmb") @db.Decimal(18, 4)
  costAdjustMethod     AppleBalanceAdjustmentCostMethod @map("cost_adjust_method")
  costRmbChange        Decimal                          @map("cost_rmb_change") @db.Decimal(18, 4)
  reason               String                           @db.Text
  evidenceAttachmentId String?                          @map("evidence_attachment_id") @db.Uuid
  operatorId           String?                          @map("operator_id") @db.Uuid
  createdAt            DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)

  appleAccount       AppleAccount @relation(fields: [appleAccountId], references: [id], onDelete: Restrict)
  evidenceAttachment Attachment?  @relation("AppleBalanceAdjustmentEvidence", fields: [evidenceAttachmentId], references: [id], onDelete: SetNull)
  operator           User?        @relation("AppleBalanceAdjustmentOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([appleAccountId])
  @@index([costAdjustMethod])
  @@index([evidenceAttachmentId])
  @@index([operatorId])
  @@index([createdAt])
  @@map("apple_balance_adjustments")
}

model AppleAccountStatusCheck {
  id                   String                      @id @default(uuid()) @db.Uuid
  appleAccountId       String                      @map("apple_account_id") @db.Uuid
  checkType            AppleAccountStatusCheckType @default(manual) @map("check_type")
  resultStatus         AppleAccountStatus          @map("result_status")
  balanceSnapshot      Decimal?                    @map("balance_snapshot") @db.Decimal(18, 4)
  remark               String?                     @db.Text
  evidenceAttachmentId String?                     @map("evidence_attachment_id") @db.Uuid
  operatorId           String?                     @map("operator_id") @db.Uuid
  createdAt            DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  appleAccount       AppleAccount @relation(fields: [appleAccountId], references: [id], onDelete: Restrict)
  evidenceAttachment Attachment?  @relation("AppleAccountStatusCheckEvidence", fields: [evidenceAttachmentId], references: [id], onDelete: SetNull)
  operator           User?        @relation("AppleAccountStatusCheckOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([appleAccountId])
  @@index([checkType])
  @@index([resultStatus])
  @@index([evidenceAttachmentId])
  @@index([operatorId])
  @@index([createdAt])
  @@map("apple_account_status_checks")
}

model AppleService {
  id                    String                     @id @default(uuid()) @db.Uuid
  name                  String                     @db.VarChar(120)
  category              String                     @default("default") @db.VarChar(80)
  defaultPrice          Decimal                    @default(0) @map("default_price") @db.Decimal(18, 2)
  officialCostValue     Decimal                    @default(0) @map("official_cost_value") @db.Decimal(18, 4)
  currency              String                     @default("USD") @db.VarChar(10)
  defaultPeriodType     AppleServicePeriodType     @default(month) @map("default_period_type")
  defaultPeriodValue    Int                        @default(1) @map("default_period_value")
  expireCalcType        AppleServiceExpireCalcType @default(by_month) @map("expire_calc_type")
  requireAppleId        Boolean                    @default(true) @map("require_apple_id")
  requireServiceAccount Boolean                    @default(false) @map("require_service_account")
  autoMatchAppleId      Boolean                    @default(true) @map("auto_match_apple_id")
  lockRule              AppleServiceLockRule       @default(by_service) @map("lock_rule")
  allowedRegions        String[]                   @default([]) @map("allowed_regions")
  minBalanceRequired    Decimal                    @default(0) @map("min_balance_required") @db.Decimal(18, 4)
  status                AppleServiceStatus         @default(enabled)
  remark                String?                    @db.Text
  createdByUserId       String?                    @map("created_by_user_id") @db.Uuid
  updatedByUserId       String?                    @map("updated_by_user_id") @db.Uuid
  createdAt             DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?                  @map("deleted_at") @db.Timestamptz(6)

  createdBy        User?                         @relation("AppleServiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy        User?                         @relation("AppleServiceUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  orders           AppleOrder[]
  activations      ServiceActivation[]
  locks            AppleAccountLock[]
  renewalTasks     RenewalTask[]
  actionPlanItems  AppleAccountActionPlanItem[]
  platformMappings AppleServicePlatformMapping[]
  automationTasks  AutomationTask[]

  @@index([category])
  @@index([currency])
  @@index([status])
  @@index([deletedAt])
  @@map("apple_services")
}

model AppleServicePlatformMapping {
  id               String                      @id @default(uuid()) @db.Uuid
  serviceId        String                      @map("service_id") @db.Uuid
  sourcePlatformId String                      @map("source_platform_id") @db.Uuid
  shopName         String?                     @map("shop_name") @db.VarChar(120)
  platformItemId   String                      @map("platform_item_id") @db.VarChar(120)
  platformSkuId    String                      @default("") @map("platform_sku_id") @db.VarChar(120)
  skuKeyword       String?                     @map("sku_keyword") @db.VarChar(255)
  platformPrice    Decimal                     @default(0) @map("platform_price") @db.Decimal(18, 2)
  platformFeeType  AppleServicePlatformFeeType @default(none) @map("platform_fee_type")
  platformFeeValue Decimal                     @default(0) @map("platform_fee_value") @db.Decimal(18, 4)
  allowAutoOrder   Boolean                     @default(false) @map("allow_auto_order")
  enabled          Boolean                     @default(true)
  createdAt        DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  service        AppleService   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  sourcePlatform SourcePlatform @relation(fields: [sourcePlatformId], references: [id], onDelete: Restrict)

  @@unique([serviceId, sourcePlatformId, platformItemId, platformSkuId])
  @@index([serviceId])
  @@index([sourcePlatformId])
  @@index([enabled])
  @@map("apple_service_platform_mappings")
}

model CodeService {
  id                 String            @id @default(uuid()) @db.Uuid
  name               String            @db.VarChar(120)
  faceValue          Decimal           @map("face_value") @db.Decimal(18, 4)
  defaultPrice       Decimal           @default(0) @map("default_price") @db.Decimal(18, 2)
  defaultCost        Decimal           @default(0) @map("default_cost") @db.Decimal(18, 2)
  deliveryMode       CodeDeliveryMode  @default(semi_auto) @map("delivery_mode")
  exactFaceValueOnly Boolean           @default(true) @map("exact_face_value_only")
  allowCombination   Boolean           @default(false) @map("allow_combination")
  status             CodeServiceStatus @default(enabled)
  remark             String?           @db.Text
  createdByUserId    String?           @map("created_by_user_id") @db.Uuid
  updatedByUserId    String?           @map("updated_by_user_id") @db.Uuid
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?         @map("deleted_at") @db.Timestamptz(6)

  createdBy        User?                 @relation("CodeServiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy        User?                 @relation("CodeServiceUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  batches          RedeemCodeBatch[]
  codes            RedeemCode[]
  platformMappings CodePlatformMapping[]
  platformOrders   CodePlatformOrder[]

  @@index([faceValue])
  @@index([status])
  @@index([deletedAt])
  @@map("code_services")
}

model CodePlatformMapping {
  id                 String   @id @default(uuid()) @db.Uuid
  platformId         String   @map("platform_id") @db.Uuid
  shopId             String?  @map("shop_id") @db.VarChar(120)
  platformItemId     String   @map("platform_item_id") @db.VarChar(120)
  platformSkuId      String   @default("") @map("platform_sku_id") @db.VarChar(120)
  skuKeyword         String?  @map("sku_keyword") @db.VarChar(255)
  serviceId          String   @map("service_id") @db.Uuid
  faceValue          Decimal  @map("face_value") @db.Decimal(18, 4)
  quantity           Int      @default(1)
  deliveryTemplateId String?  @map("delivery_template_id") @db.Uuid
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  platform         SourcePlatform   @relation(fields: [platformId], references: [id], onDelete: Restrict)
  service          CodeService      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  deliveryTemplate MessageTemplate? @relation("CodePlatformMappingDeliveryTemplate", fields: [deliveryTemplateId], references: [id], onDelete: SetNull)

  @@unique([platformId, platformItemId, platformSkuId, serviceId])
  @@index([platformId])
  @@index([serviceId])
  @@index([platformItemId])
  @@index([platformSkuId])
  @@index([enabled])
  @@map("code_platform_mappings")
}

model CodePlatformOrder {
  id              String             @id @default(uuid()) @db.Uuid
  platformId      String             @map("platform_id") @db.Uuid
  externalOrderNo String             @map("external_order_no") @db.VarChar(120)
  buyerId         String?            @map("buyer_id") @db.VarChar(120)
  buyerNameMasked String?            @map("buyer_name_masked") @db.VarChar(120)
  itemId          String             @map("item_id") @db.VarChar(120)
  skuId           String             @default("") @map("sku_id") @db.VarChar(120)
  itemTitle       String?            @map("item_title") @db.VarChar(255)
  skuName         String?            @map("sku_name") @db.VarChar(255)
  serviceId       String?            @map("service_id") @db.Uuid
  faceValue       Decimal?           @map("face_value") @db.Decimal(18, 4)
  quantity        Int                @default(1)
  paidAmount      Decimal            @default(0) @map("paid_amount") @db.Decimal(18, 2)
  platformFee     Decimal            @default(0) @map("platform_fee") @db.Decimal(18, 2)
  costAmount      Decimal            @default(0) @map("cost_amount") @db.Decimal(18, 2)
  profitAmount    Decimal            @default(0) @map("profit_amount") @db.Decimal(18, 2)
  orderStatus     String             @default("paid") @map("order_status") @db.VarChar(80)
  deliveryStatus  CodeDeliveryStatus @default(pending) @map("delivery_status")
  refundStatus    CodeRefundStatus   @default(none) @map("refund_status")
  paidAt          DateTime?          @map("paid_at") @db.Timestamptz(6)
  deliveredAt     DateTime?          @map("delivered_at") @db.Timestamptz(6)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  platform       SourcePlatform     @relation(fields: [platformId], references: [id], onDelete: Restrict)
  service        CodeService?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  lockedCodes    RedeemCode[]       @relation("RedeemCodeLockedOrder")
  deliveredCodes RedeemCode[]       @relation("RedeemCodeDeliveredOrder")
  deliveryLogs   CodeDeliveryLog[]
  afterSales     CodeAfterSale[]
  refundRecords  CodeRefundRecord[]

  @@unique([platformId, externalOrderNo])
  @@index([platformId])
  @@index([serviceId])
  @@index([itemId])
  @@index([skuId])
  @@index([deliveryStatus])
  @@index([refundStatus])
  @@index([createdAt])
  @@map("code_platform_orders")
}

model CodeDeliveryLog {
  id                      String                @id @default(uuid()) @db.Uuid
  orderId                 String                @map("order_id") @db.Uuid
  platformId              String                @map("platform_id") @db.Uuid
  externalOrderNo         String                @map("external_order_no") @db.VarChar(120)
  codeId                  String                @map("code_id") @db.Uuid
  faceValue               Decimal               @map("face_value") @db.Decimal(18, 4)
  deliveryMethod          CodeDeliveryMethod    @map("delivery_method")
  deliveryContentSnapshot String                @map("delivery_content_snapshot") @db.Text
  deliveryStatus          CodeDeliveryLogStatus @default(success) @map("delivery_status")
  errorMessage            String?               @map("error_message") @db.Text
  cost                    Decimal               @db.Decimal(18, 2)
  paidAmount              Decimal               @map("paid_amount") @db.Decimal(18, 2)
  profit                  Decimal               @db.Decimal(18, 2)
  createdAt               DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  order    CodePlatformOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  platform SourcePlatform    @relation(fields: [platformId], references: [id], onDelete: Restrict)
  code     RedeemCode        @relation(fields: [codeId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([platformId])
  @@index([codeId])
  @@index([externalOrderNo])
  @@index([deliveryStatus])
  @@index([createdAt])
  @@map("code_delivery_logs")
}

model CodeAfterSale {
  id              String              @id @default(uuid()) @db.Uuid
  orderId         String              @map("order_id") @db.Uuid
  originalCodeId  String              @map("original_code_id") @db.Uuid
  newCodeId       String?             @unique @map("new_code_id") @db.Uuid
  reason          String              @db.Text
  status          CodeAfterSaleStatus @default(pending)
  handledByUserId String?             @map("handled_by") @db.Uuid
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt     DateTime?           @map("completed_at") @db.Timestamptz(6)

  order        CodePlatformOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  originalCode RedeemCode        @relation("CodeAfterSaleOriginalCode", fields: [originalCodeId], references: [id], onDelete: Restrict)
  newCode      RedeemCode?       @relation("CodeAfterSaleNewCode", fields: [newCodeId], references: [id], onDelete: Restrict)
  handledBy    User?             @relation("CodeAfterSaleHandledBy", fields: [handledByUserId], references: [id], onDelete: SetNull)

  @@unique([orderId, originalCodeId])
  @@index([orderId, status])
  @@index([originalCodeId])
  @@index([newCodeId])
  @@index([handledByUserId])
  @@index([createdAt])
  @@map("code_after_sales")
}

model CodeRefundRecord {
  id               String                 @id @default(uuid()) @db.Uuid
  orderId          String                 @map("order_id") @db.Uuid
  platformId       String                 @map("platform_id") @db.Uuid
  externalRefundNo String                 @map("external_refund_no") @db.VarChar(120)
  refundAmount     Decimal                @map("refund_amount") @db.Decimal(18, 2)
  status           CodeRefundRecordStatus @default(refunding)
  reason           String?                @db.Text
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  order    CodePlatformOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  platform SourcePlatform    @relation(fields: [platformId], references: [id], onDelete: Restrict)

  @@unique([platformId, externalRefundNo])
  @@index([orderId])
  @@index([platformId])
  @@index([status])
  @@index([createdAt])
  @@map("code_refund_records")
}

model RedeemCodeBatch {
  id           String   @id @default(uuid()) @db.Uuid
  batchNo      String   @unique @map("batch_no") @db.VarChar(80)
  serviceId    String   @map("service_id") @db.Uuid
  faceValue    Decimal  @map("face_value") @db.Decimal(18, 4)
  totalCount   Int      @default(0) @map("total_count")
  successCount Int      @default(0) @map("success_count")
  failedCount  Int      @default(0) @map("failed_count")
  defaultCost  Decimal  @default(0) @map("default_cost") @db.Decimal(18, 2)
  remark       String?  @db.Text
  importedById String?  @map("imported_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  service    CodeService  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  importedBy User?        @relation("RedeemCodeBatchImportedBy", fields: [importedById], references: [id], onDelete: SetNull)
  codes      RedeemCode[]

  @@index([serviceId])
  @@index([faceValue])
  @@index([createdAt])
  @@map("redeem_code_batches")
}

model RedeemCode {
  id                  String           @id @default(uuid()) @db.Uuid
  serviceId           String           @map("service_id") @db.Uuid
  batchId             String           @map("batch_id") @db.Uuid
  codeEncrypted       String           @map("code_encrypted") @db.Text
  codeHash            String           @unique @map("code_hash") @db.VarChar(128)
  codeTail            String           @map("code_tail") @db.VarChar(8)
  faceValue           Decimal          @map("face_value") @db.Decimal(18, 4)
  cost                Decimal          @db.Decimal(18, 2)
  status              RedeemCodeStatus @default(unsold)
  lockedOrderId       String?          @map("locked_order_id") @db.Uuid
  deliveredOrderId    String?          @map("delivered_order_id") @db.Uuid
  deliveredPlatformId String?          @map("delivered_platform_id") @db.Uuid
  deliveredAt         DateTime?        @map("delivered_at") @db.Timestamptz(6)
  expireAt            DateTime?        @map("expire_at") @db.Timestamptz(6)
  remark              String?          @db.Text
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  service            CodeService        @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  batch              RedeemCodeBatch    @relation(fields: [batchId], references: [id], onDelete: Restrict)
  lockedOrder        CodePlatformOrder? @relation("RedeemCodeLockedOrder", fields: [lockedOrderId], references: [id], onDelete: SetNull)
  deliveredOrder     CodePlatformOrder? @relation("RedeemCodeDeliveredOrder", fields: [deliveredOrderId], references: [id], onDelete: SetNull)
  deliveredPlatform  SourcePlatform?    @relation("RedeemCodeDeliveredPlatform", fields: [deliveredPlatformId], references: [id], onDelete: SetNull)
  deliveryLogs       CodeDeliveryLog[]
  originalAfterSales CodeAfterSale[]    @relation("CodeAfterSaleOriginalCode")
  newAfterSale       CodeAfterSale?     @relation("CodeAfterSaleNewCode")

  @@index([serviceId, status])
  @@index([faceValue, status])
  @@index([batchId])
  @@index([deliveredOrderId])
  @@index([expireAt])
  @@map("redeem_codes")
}

model AppleOrder {
  id               String           @id @default(uuid()) @db.Uuid
  orderNo          String           @unique @map("order_no") @db.VarChar(40)
  customerId       String           @map("customer_id") @db.Uuid
  sourcePlatformId String?          @map("source_platform_id") @db.Uuid
  externalOrderNo  String?          @map("external_order_no") @db.VarChar(120)
  serviceId        String           @map("service_id") @db.Uuid
  appleAccountId   String?          @map("apple_account_id") @db.Uuid
  serviceAccount   String?          @map("service_account") @db.VarChar(255)
  currentPlan      String?          @map("current_plan") @db.VarChar(120)
  targetPlan       String?          @map("target_plan") @db.VarChar(120)
  startTime        DateTime?        @map("start_time") @db.Timestamptz(6)
  expireTime       DateTime?        @map("expire_time") @db.Timestamptz(6)
  paidAmount       Decimal          @default(0) @map("paid_amount") @db.Decimal(18, 2)
  platformFee      Decimal          @default(0) @map("platform_fee") @db.Decimal(18, 2)
  refundLoss       Decimal          @default(0) @map("refund_loss") @db.Decimal(18, 2)
  appleCostValue   Decimal          @default(0) @map("apple_cost_value") @db.Decimal(18, 4)
  appleCostRmb     Decimal          @default(0) @map("apple_cost_rmb") @db.Decimal(18, 4)
  profitAmount     Decimal          @default(0) @map("profit_amount") @db.Decimal(18, 4)
  status           AppleOrderStatus @default(active)
  remark           String?          @db.Text
  createdByUserId  String?          @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?          @map("updated_by_user_id") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  sourcePlatform SourcePlatform?    @relation(fields: [sourcePlatformId], references: [id], onDelete: SetNull)
  service        AppleService       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appleAccount   AppleAccount?      @relation(fields: [appleAccountId], references: [id], onDelete: Restrict)
  createdBy      User?              @relation("AppleOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy      User?              @relation("AppleOrderUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  activation     ServiceActivation?
  locks          AppleAccountLock[]
  renewalTasks   RenewalTask[]

  @@unique([sourcePlatformId, externalOrderNo])
  @@index([customerId])
  @@index([sourcePlatformId])
  @@index([serviceId])
  @@index([appleAccountId])
  @@index([status])
  @@index([createdAt])
  @@map("apple_orders")
}

model ServiceActivation {
  id               String                  @id @default(uuid()) @db.Uuid
  orderId          String                  @unique @map("order_id") @db.Uuid
  customerId       String                  @map("customer_id") @db.Uuid
  appleAccountId   String?                 @map("apple_account_id") @db.Uuid
  serviceId        String                  @map("service_id") @db.Uuid
  currentPlan      String?                 @map("current_plan") @db.VarChar(120)
  targetPlan       String?                 @map("target_plan") @db.VarChar(120)
  startTime        DateTime?               @map("start_time") @db.Timestamptz(6)
  expireTime       DateTime?               @map("expire_time") @db.Timestamptz(6)
  consumedValue    Decimal                 @default(0) @map("consumed_value") @db.Decimal(18, 4)
  currency         String                  @default("USD") @db.VarChar(10)
  avgUnitCost      Decimal                 @default(0) @map("avg_unit_cost") @db.Decimal(18, 8)
  costRmb          Decimal                 @default(0) @map("cost_rmb") @db.Decimal(18, 4)
  paidAmount       Decimal                 @default(0) @map("paid_amount") @db.Decimal(18, 2)
  platformFee      Decimal                 @default(0) @map("platform_fee") @db.Decimal(18, 2)
  refundLoss       Decimal                 @default(0) @map("refund_loss") @db.Decimal(18, 2)
  profitAmount     Decimal                 @default(0) @map("profit_amount") @db.Decimal(18, 4)
  sourcePlatformId String?                 @map("source_platform_id") @db.Uuid
  externalOrderNo  String?                 @map("external_order_no") @db.VarChar(120)
  status           ServiceActivationStatus @default(active)
  autoRenewStatus  AutoRenewStatus         @default(unknown) @map("auto_renew_status")
  renewalDecision  RenewalDecision         @default(unconfirmed) @map("renewal_decision")
  renewalNote      String?                 @map("renewal_note") @db.Text
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  order           AppleOrder                   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  customer        Customer                     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  appleAccount    AppleAccount?                @relation(fields: [appleAccountId], references: [id], onDelete: Restrict)
  service         AppleService                 @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  sourcePlatform  SourcePlatform?              @relation(fields: [sourcePlatformId], references: [id], onDelete: SetNull)
  renewalTasks    RenewalTask[]
  actionPlanItems AppleAccountActionPlanItem[]
  automationTasks AutomationTask[]

  @@index([customerId])
  @@index([appleAccountId])
  @@index([serviceId])
  @@index([expireTime])
  @@index([status])
  @@map("service_activations")
}

model AppleAccountLock {
  id              String                 @id @default(uuid()) @db.Uuid
  appleAccountId  String                 @map("apple_account_id") @db.Uuid
  serviceId       String?                @map("service_id") @db.Uuid
  orderId         String?                @map("order_id") @db.Uuid
  lockScope       AppleAccountLockScope  @default(by_service) @map("lock_scope")
  status          AppleAccountLockStatus @default(active)
  reason          String?                @db.Text
  lockedAt        DateTime               @default(now()) @map("locked_at") @db.Timestamptz(6)
  releasedAt      DateTime?              @map("released_at") @db.Timestamptz(6)
  createdByUserId String?                @map("created_by_user_id") @db.Uuid
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  appleAccount AppleAccount  @relation(fields: [appleAccountId], references: [id], onDelete: Restrict)
  service      AppleService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  order        AppleOrder?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdBy    User?         @relation("AppleAccountLockCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([appleAccountId, status])
  @@index([serviceId, status])
  @@index([orderId])
  @@index([lockScope, status])
  @@map("apple_account_locks")
}

model RenewalTask {
  id                   String                      @id @default(uuid()) @db.Uuid
  taskType             RenewalTaskType             @map("task_type")
  title                String                      @db.VarChar(160)
  status               RenewalTaskStatus           @default(pending)
  priority             RenewalTaskPriority         @default(medium)
  customerId           String                      @map("customer_id") @db.Uuid
  appleAccountId       String?                     @map("apple_account_id") @db.Uuid
  serviceId            String                      @map("service_id") @db.Uuid
  activationId         String                      @map("activation_id") @db.Uuid
  orderId              String                      @map("order_id") @db.Uuid
  currentPlan          String?                     @map("current_plan") @db.VarChar(120)
  targetPlan           String?                     @map("target_plan") @db.VarChar(120)
  customerDecision     RenewalTaskCustomerDecision @default(not_contacted) @map("customer_decision")
  requiredAction       String?                     @map("required_action") @db.VarChar(160)
  currentBalance       Decimal                     @default(0) @map("current_balance") @db.Decimal(18, 4)
  expectedChargeAmount Decimal                     @default(0) @map("expected_charge_amount") @db.Decimal(18, 4)
  suggestedTopupAmount Decimal                     @default(0) @map("suggested_topup_amount") @db.Decimal(18, 4)
  expectedChargeTime   DateTime?                   @map("expected_charge_time") @db.Timestamptz(6)
  cancelDeadline       DateTime?                   @map("cancel_deadline") @db.Timestamptz(6)
  remindAt             DateTime?                   @map("remind_at") @db.Timestamptz(6)
  dueAt                DateTime?                   @map("due_at") @db.Timestamptz(6)
  assignedToUserId     String?                     @map("assigned_to") @db.Uuid
  note                 String?                     @db.Text
  resultNote           String?                     @map("result_note") @db.Text
  evidenceAttachmentId String?                     @map("evidence_attachment_id") @db.Uuid
  createdByUserId      String?                     @map("created_by") @db.Uuid
  completedByUserId    String?                     @map("completed_by") @db.Uuid
  createdAt            DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  completedAt          DateTime?                   @map("completed_at") @db.Timestamptz(6)

  customer           Customer                     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  appleAccount       AppleAccount?                @relation(fields: [appleAccountId], references: [id], onDelete: SetNull)
  service            AppleService                 @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  activation         ServiceActivation            @relation(fields: [activationId], references: [id], onDelete: Restrict)
  order              AppleOrder                   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  assignedTo         User?                        @relation("RenewalTaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy          User?                        @relation("RenewalTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  completedBy        User?                        @relation("RenewalTaskCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  evidenceAttachment Attachment?                  @relation(fields: [evidenceAttachmentId], references: [id], onDelete: SetNull)
  actionPlanItems    AppleAccountActionPlanItem[]

  @@index([status])
  @@index([taskType])
  @@index([priority])
  @@index([customerId])
  @@index([appleAccountId])
  @@index([serviceId])
  @@index([activationId])
  @@index([orderId])
  @@index([dueAt])
  @@index([assignedToUserId])
  @@index([customerDecision])
  @@map("renewal_tasks")
}

model AppleAccountActionPlan {
  id                    String                @id @default(uuid()) @db.Uuid
  appleAccountId        String                @map("apple_account_id") @db.Uuid
  planDate              DateTime              @map("plan_date") @db.Date
