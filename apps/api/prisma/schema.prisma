  @@index([userId, tableKey, isDefault])
  @@map("user_table_views")
}

model DataDictionary {
  id              String               @id @default(uuid()) @db.Uuid
  group           String               @db.VarChar(80)
  code            String               @db.VarChar(120)
  label           String               @db.VarChar(160)
  value           String?              @db.VarChar(255)
  sortOrder       Int                  @default(0) @map("sort_order")
  status          DataDictionaryStatus @default(active)
  remark          String?              @db.Text
  createdByUserId String?              @map("created_by_user_id") @db.Uuid
  updatedByUserId String?              @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy User? @relation("DataDictionaryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User? @relation("DataDictionaryUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([group, code])
  @@index([group])
  @@index([status])
  @@index([sortOrder])
  @@map("data_dictionaries")
}

