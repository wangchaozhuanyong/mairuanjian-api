# Runtime
NODE_ENV=production
APP_NAME=apple-id-business-system
APP_PUBLIC_URL=https://example.com
CORS_ORIGIN=https://example.com
FIRST_RELEASE_MODE=semi_auto
ADMIN_HTTP_PORT=8080

# Database container
POSTGRES_DB=apple_business
POSTGRES_USER=apple_business
POSTGRES_PASSWORD=replace_with_strong_database_password

# API secrets
JWT_SECRET=replace_with_long_random_jwt_secret
JWT_EXPIRES_IN=7d
FIELD_ENCRYPTION_KEY=replace_with_32_bytes_minimum_random_key
HASH_SECRET=replace_with_long_random_hash_secret

# Seed admin. Set only for first initialization, then remove or rotate.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace_with_strong_admin_password
SEED_ADMIN_DISPLAY_NAME=管理员

# MinIO
MINIO_ROOT_USER=replace_with_minio_root_user
MINIO_ROOT_PASSWORD=replace_with_strong_minio_password
MINIO_ACCESS_KEY=replace_with_minio_root_user
MINIO_SECRET_KEY=replace_with_strong_minio_password
MINIO_BUCKET=attachments

# Frontend build
VITE_APP_TITLE=Apple ID 代充业务管理系统

# Runtime files
DATA_IMPORT_DIR=uploads/data-imports
DATA_IMPORT_ERROR_DIR=uploads/data-import-errors
DATA_EXPORT_DIR=uploads/data-exports
DATA_BACKUP_DIR=backups/postgres
DATA_JOB_COMMAND_TIMEOUT_MS=600000

# Ops retention
BACKUP_RETENTION_DAYS=14
BACKUP_RETENTION_COUNT=30
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=10

# Platform placeholders
PLATFORM_POLL_ENABLED=false
PLATFORM_POLL_INTERVAL_MS=300000
PLATFORM_POLL_RUN_ON_STARTUP=false
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
XIANYU_APP_KEY=
XIANYU_APP_SECRET=

# Apple official price polling
APPLE_OFFICIAL_PRICE_POLL_ENABLED=false
APPLE_OFFICIAL_PRICE_POLL_INTERVAL_MS=21600000
APPLE_OFFICIAL_PRICE_POLL_RUN_ON_STARTUP=false
APPLE_OFFICIAL_PRICE_POLL_BOOTSTRAP_PROVIDERS=false

# Apple web status check worker
# Keep disabled until sing-box sidecar and Playwright browser runtime are deployed.
APPLE_WEB_CHECK_GATEWAY_REGIONS=
APPLE_WEB_CHECK_ADAPTER_VERSION=apple-web-v1
APPLE_WEB_CHECK_WORKER_ENABLED=false
APPLE_WEB_CHECK_WORKER_INTERVAL_MS=60000
APPLE_WEB_CHECK_WORKER_RUN_ON_STARTUP=false
APPLE_WEB_CHECK_WORKER_MAX_BATCH=3
APPLE_WEB_CHECK_TIMEOUT_MS=45000
APPLE_WEB_CHECK_HEADLESS=true
APPLE_WEB_CHECK_PROXY_SERVER=socks5://127.0.0.1:2080
APPLE_WEB_CHECK_SING_BOX_API_URL=http://127.0.0.1:9090
APPLE_WEB_CHECK_SING_BOX_SELECTOR=apple-web
APPLE_WEB_CHECK_SING_BOX_API_SECRET=
APPLE_WEB_CHECK_IP_CHECK_URL=https://ipapi.co/json/
