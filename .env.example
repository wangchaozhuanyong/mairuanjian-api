# App
NODE_ENV=development
APP_PORT=3000
APP_NAME=apple-id-business-system
CORS_ORIGIN=http://localhost:5374
FIRST_RELEASE_MODE=semi_auto

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/apple_business?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# Seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change_me_admin_password
SEED_ADMIN_DISPLAY_NAME=管理员

# Encryption
FIELD_ENCRYPTION_KEY=change_me_32_bytes_minimum
HASH_SECRET=change_me_hash_secret

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=attachments
MINIO_USE_SSL=false

# Local attachments
ATTACHMENT_STORAGE_DIR=uploads
DATA_IMPORT_DIR=uploads/data-imports
DATA_IMPORT_ERROR_DIR=uploads/data-import-errors
DATA_EXPORT_DIR=uploads/data-exports
DATA_BACKUP_DIR=backups/postgres/local
DATA_JOB_COMMAND_TIMEOUT_MS=600000

# Frontend
VITE_API_BASE_URL=http://localhost:3000/api
VITE_APP_TITLE=Apple ID 代充业务管理系统

# Ops retention
BACKUP_RETENTION_DAYS=14
BACKUP_RETENTION_COUNT=30
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=10

# Platform placeholders
PLATFORM_POLL_ENABLED=false
PLATFORM_POLL_INTERVAL_MS=300000
PLATFORM_POLL_RUN_ON_STARTUP=false
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
XIANYU_APP_KEY=
XIANYU_APP_SECRET=
